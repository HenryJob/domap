SECRET_KEY=change-me-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# --- WhatsApp automático (Evolution API) -----------------------------------
# Clave global de Evolution API. Genera una larga y secreta, p. ej.:
#   docker run --rm python:3.12-slim python -c "import secrets; print(secrets.token_urlsafe(32))"
EVOLUTION_API_KEY=change-me-evolution-key
# URL pública de Evolution (para armar el QR). En local déjalo así.
EVOLUTION_SERVER_URL=http://localhost:8080
# URL interna que usa Django para hablar con Evolution (nombre del servicio Compose).
EVOLUTION_API_URL=http://evolution-api:8080
# Nombre de la instancia (el "teléfono" conectado). Cualquier identificador.
EVOLUTION_INSTANCE=morde
# Código de país por defecto para normalizar los teléfonos de los clientes.
WHATSAPP_COUNTRY_CODE=51
# Pon True SOLO después de conectar el número escaneando el QR.
WHATSAPP_NOTIFY_ENABLED=False
# Versión de WhatsApp Web (opcional). Solo cámbiala si el QR deja de aparecer;
# valores vigentes en https://github.com/wppconnect-team/wa-version
# WHATSAPP_WEB_VERSION=2.3000.1042623402
